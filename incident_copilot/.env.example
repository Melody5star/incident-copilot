# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# Gemini / Vertex AI
GEMINI_MODEL=gemini-2.5-pro-preview-05-06

# Elastic — self-hosted (default, free, no trial limits)
ELASTIC_HOSTS=http://localhost:9200
ELASTIC_INDEX_PATTERN=logs-*
# Elastic Cloud (optional — only if using cloud.elastic.co instead)
# ELASTIC_CLOUD_ID=your-elastic-cloud-id
# ELASTIC_API_KEY=your-elastic-api-key

# GitLab
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=your-gitlab-personal-access-token
GITLAB_PROJECT_ID=your-target-project-id

# Arize Phoenix (LLM observability)
PHOENIX_API_KEY=your-arize-phoenix-api-key
PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
PHOENIX_PROJECT_NAME=incident-copilot

# App
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO
